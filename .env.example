# --- Core ---
APP_NAME=AgentOn
ENV=development
SECRET_KEY=change-me-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ---
# SQLite is fine for local dev. Use Postgres in production (billing needs real ACID guarantees).
DATABASE_URL=sqlite:///./agenton.db
# DATABASE_URL=postgresql+psycopg2://agenton:agenton@localhost:5432/agenton

# --- Billing ---
# Which payment provider implementation to load. "mock" simulates payments
# for dev/testing; "stripe" enables real hosted-checkout recharges below.
PAYMENT_PROVIDER=mock
LOW_BALANCE_THRESHOLD_CENTS=500
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Instance scheduler ---
INSTANCE_TICK_SECONDS=30

# --- Execution engine ---
# Path to the `claude` CLI binary used by the ai_content connector (CLI-as-brain pattern).
CLAUDE_CLI_PATH=claude
CLAUDE_CLI_IDLE_TIMEOUT_SECONDS=180

# --- Third-party connectors / OAuth (fill in when going live) ---
# X (Twitter) OAuth2 app credentials — used for the /platforms/twitter/* connect flow.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:8000/platforms/twitter/callback

# Discord application credentials. DISCORD_BOT_TOKEN is the bot user that
# actually performs discord_join; DISCORD_CLIENT_ID/SECRET are the OAuth2
# app credentials used for the /platforms/discord/* connect flow (usually
# the same Discord Application, different credential types).
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8000/platforms/discord/callback
